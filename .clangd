# clangd configuration for MSVC-based C/C++ project
# This file must be in the project root directory

CompileFlags:
  # Use the compilation database generated by CMake/Ninja
  CompilationDatabase: build_ninja
  
  # Add MSVC compatibility flags
  Add:
    # MSVC target and compatibility
    - --target=x86_64-pc-windows-msvc
    - -fms-compatibility-version=19.34
    - -fms-extensions
    - -fdelayed-template-parsing
    - -Wno-microsoft-cast
    - -Wno-microsoft-exception-spec
    - -Wno-microsoft-include
    
    # Standard C headers (stdlib.h, stdio.h, etc.)
    # These are in the Universal C Runtime (ucrt)
    - /imsvc
    - C:/Program Files (x86)/Windows Kits/10/Include/10.0.22621.0/ucrt
    
    # MSVC STL headers (C++ standard library)
    - /imsvc
    - C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/MSVC/14.34.31933/include
    
    # Windows SDK headers
    # Order matters: shared before um
    - /imsvc
    - C:/Program Files (x86)/Windows Kits/10/Include/10.0.22621.0/shared
    - /imsvc
    - C:/Program Files (x86)/Windows Kits/10/Include/10.0.22621.0/um
    
    # Additional Windows SDK paths
    - /imsvc
    - C:/Program Files (x86)/Windows Kits/10/Include/10.0.22621.0/winrt
    - /imsvc
    - C:/Program Files (x86)/Windows Kits/NETFXSDK/4.8/Include/um
  
  # Remove MSVC-specific flags that clang doesn't understand
  Remove:
    - /W4
    - /GS
    - /guard:cf
    - /Fd*
    - /Fo*
    - /FS
    - /Ob0
    - /Od
    - /RTC1
    - /Zi
    - /nologo

# Query MSVC compiler for system includes and defines
# This can help clangd find additional system headers
QueryDriver:
  - "C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/MSVC/14.34.31933/bin/Hostx64/x64/cl.exe"

# Diagnostics configuration
Diagnostics:
  # Suppress warnings that don't apply to MSVC code
  Suppress:
    - "missing-field-initializers"
    - "unused-parameter"
    - "unused-variable"
  UnusedIncludes: Strict
  MissingIncludes: Warning

# Index configuration for better performance
Index:
  Background: Build
  StandardLibrary: true
  MultiVersion: true

# Format configuration (optional)
Format:
  Style: file
  BasedOnStyle: LLVM